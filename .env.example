# -----------------------------------------
# VITAL TRAINING — Variables de entorno
# Copia este archivo como .env y ajusta los valores
# -----------------------------------------

# Puerto del servidor (por defecto 4000)
PORT=4000

# Clave secreta para firmar tokens JWT
# IMPORTANTE: cambiar por una clave segura en produccion
JWT_SECRET=vt-super-secret-key-2026

# Tiempo de expiracion del token (ejemplos: 8h, 1d, 7d)
JWT_EXPIRES_IN=8h
